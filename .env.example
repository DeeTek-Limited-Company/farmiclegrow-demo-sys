# App
NEXT_PUBLIC_APP_NAME=FarmicleGrow
NODE_ENV=development
AUTH_SECRET=replace-with-a-long-random-secret

# Database
DATABASE_URL=postgresql://farmiclegrow:farmiclegrow@localhost:5432/farmiclegrow?schema=public
DATABASE_URL_POOLER=
DATABASE_SSL_REJECT_UNAUTHORIZED=

# Optional seed defaults
SEED_ADMIN_EMAIL=admin@farmiclegrow.com
SEED_ADMIN_PASSWORD=ChangeMe123!

# Supabase Storage (server-side uploads)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_STORAGE_BUCKET=uploads
SUPABASE_BUCKET_DOCS=farmer-documents
SUPABASE_BUCKET_PHOTOS=profile-photos
SUPABASE_BUCKET_CERTS=certifications

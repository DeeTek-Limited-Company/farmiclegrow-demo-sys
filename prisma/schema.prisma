generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  fullName            String
  passwordHash        String
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  mustChangePassword  Boolean              @default(false)
  failedLoginAttempts Int                  @default(0)
  lockUntil           DateTime?
  organizationId      String?
  mfaEnabled          Boolean              @default(false)
  mfaSecret           String?
  agronomistDistricts AgronomistDistrict[]
  approvals           ApprovalAction[]     @relation("ApprovalActor")
  auditLogs           AuditLog[]
  buyerProfile        BuyerProfile?
  submissions         FarmerSubmission[]   @relation("SubmissionActor")
  notifications       Notification[]
  buyerOrders         Order[]              @relation("BuyerOrders")
  orderMessages       OrderMessage[]
  sessions            Session[]
  organization        Organization?        @relation(fields: [organizationId], references: [id])
  userRoles           UserRole[]

  @@index([organizationId])
}

model Session {
  id             String        @id @default(cuid())
  userId         String
  expiresAt      DateTime
  revoked        Boolean       @default(false)
  ip             String?
  userAgent      String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model Role {
  id        String     @id @default(cuid())
  key       String     @unique
  name      String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  userRoles UserRole[]
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model Farmer {
  id                  String              @id @default(cuid())
  externalRef         String?             @unique
  fullName            String
  email               String?
  phone               String?
  gender              String?
  dateOfBirth         DateTime?
  bio                 String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  certificationStatus String?
  communityId         String?
  cooperativeName     String?
  ghanaCardNumber     String?             @unique
  qualityScore        Int                 @default(0)
  yearsFarming        Int?
  primaryCrop         String?
  secondaryCrops      Json?
  organizationId      String
  batches             Batch[]
  certifications      Certification[]
  documents           Document[]
  plots               FarmPlot[]
  farmProfiles        FarmProfile[]
  community           Community?          @relation(fields: [communityId], references: [id])
  organization        Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  submissions         FarmerSubmission[]
  fieldActivities     FieldActivity[]
  harvestRecords      HarvestRecord[]
  inputTraceabilities InputTraceability[]
  plantingActivities  PlantingActivity[]
  productionRecords   ProductionRecord[]

  @@index([organizationId])
}

model FarmProfile {
  id                String             @id @default(cuid())
  farmerId          String
  farmName          String
  totalAreaHectare  Decimal?           @db.Decimal(10, 2)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  farmType          String?
  farmSize          Decimal?           @db.Decimal(10, 2)
  farmSizeUnit      String?
  ownershipType     String?
  irrigationType    String?
  numberOfPlots     Int?
  organizationId    String
  locations         FarmLocation[]
  farmer            Farmer             @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  productionRecords ProductionRecord[]

  @@index([organizationId])
}

model FarmLocation {
  id             String       @id @default(cuid())
  farmProfileId  String
  latitude       Decimal?     @db.Decimal(10, 7)
  longitude      Decimal?     @db.Decimal(10, 7)
  address        String?
  createdAt      DateTime     @default(now())
  community      String?
  district       String?
  isValidated    Boolean      @default(false)
  region         String?
  organizationId String
  farmProfile    FarmProfile  @relation(fields: [farmProfileId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model ProductionRecord {
  id                  String             @id @default(cuid())
  farmerId            String
  season              String
  cropType            String
  quantityTon         Decimal?           @db.Decimal(10, 2)
  createdAt           DateTime           @default(now())
  actualYieldTon      Decimal?           @db.Decimal(10, 2)
  cropVariety         String?
  expectedHarvestDate DateTime?
  expectedYieldTon    Decimal?           @db.Decimal(10, 2)
  farmProfileId       String?
  farmSizeHectares    Decimal?           @db.Decimal(10, 2)
  farmingMethod       String?
  actualHarvestDate   DateTime?          @map("harvestDate")
  inputsUsed          Json?
  irrigationType      String?
  notes               String?
  plantingDate        DateTime?
  plotId              String?
  status              ProductionStatus   @default(PLANNED)
  updatedAt           DateTime           @updatedAt
  organizationId      String
  batches             Batch[]
  fieldActivities     FieldActivity[]
  harvestRecords      HarvestRecord[]
  plantingActivities  PlantingActivity[]
  farmProfile         FarmProfile?       @relation(fields: [farmProfileId], references: [id])
  farmer              Farmer             @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  organization        Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plot                FarmPlot?          @relation(fields: [plotId], references: [id])

  @@index([organizationId])
}

model Batch {
  id                    String                @id @default(cuid())
  batchId               String                @unique
  farmerId              String
  productionRecordId    String
  crop                  String
  quantity              Decimal               @db.Decimal(10, 2)
  harvestDate           DateTime
  qrCode                String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  organizationId        String
  publicTraceVisibility PublicTraceVisibility @default(INHERIT)
  publicTracePolicyOverride Json?
  farmer                Farmer                @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  organization          Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  productionRecord      ProductionRecord      @relation(fields: [productionRecordId], references: [id], onDelete: Cascade)
  milestones            BatchMilestone[]
  marketplaceListing    MarketplaceListing?
  movementLogs          MovementLog[]
  orderItems            OrderItem[]
  salesRecords          SalesRecord[]
  warehouseEntries      WarehouseEntry[]

  @@index([organizationId])
}

model BatchMilestone {
  id             String       @id @default(cuid())
  batchId        String
  type           String
  status         String       @default("COMPLETED")
  location       String?
  performedBy    String?
  notes          String?
  timestamp      DateTime     @default(now())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organizationId String
  batch          Batch        @relation(fields: [batchId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([organizationId])
}

model Document {
  id             String       @id @default(cuid())
  farmerId       String
  type           String
  name           String
  url            String
  status         String       @default("UPLOADED")
  metadata       Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organizationId String
  farmer         Farmer       @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model Certification {
  id             String       @id @default(cuid())
  farmerId       String
  name           String
  issuer         String?
  validFrom      DateTime?
  validTo        DateTime?
  documentUrl    String?
  createdAt      DateTime     @default(now())
  organizationId String
  farmer         Farmer       @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model FarmerSubmission {
  id               String           @id @default(cuid())
  farmerId         String
  submittedById    String
  status           SubmissionStatus @default(PENDING_REVIEW)
  rejectionReason  String?
  submittedAt      DateTime         @default(now())
  decidedAt        DateTime?
  dataQualityScore Int              @default(0)
  organizationId   String
  approvalActions  ApprovalAction[]
  farmer           Farmer           @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  submittedBy      User             @relation("SubmissionActor", fields: [submittedById], references: [id])

  @@index([organizationId])
}

model ApprovalAction {
  id             String           @id @default(cuid())
  submissionId   String
  actorUserId    String
  action         SubmissionStatus
  reason         String?
  changeSet      Json?
  createdAt      DateTime         @default(now())
  organizationId String
  actor          User             @relation("ApprovalActor", fields: [actorUserId], references: [id])
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  submission     FarmerSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model Notification {
  id             String           @id @default(cuid())
  userId         String
  type           NotificationType
  title          String
  body           String?
  isRead         Boolean          @default(false)
  metadata       Json?
  createdAt      DateTime         @default(now())
  readAt         DateTime?
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model AuditLog {
  id             String        @id @default(cuid())
  action         String
  userId         String?
  details        Json?
  ip             String?
  userAgent      String?
  status         String        @default("SUCCESS")
  createdAt      DateTime      @default(now())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  user           User?         @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([userId])
}

model Organization {
  id                  String               @id @default(cuid())
  name                String
  slug                String               @unique
  status              OrganizationStatus   @default(ACTIVE)
  publicTraceEnabled  Boolean              @default(true)
  publicTracePolicy   Json?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  country             String?
  email               String?
  logoUrl             String?
  phone               String?
  region              String?
  subscriptionPlan    String               @default("STARTER")
  subscriptionStatus  String               @default("TRIAL")
  timezone            String?              @default("UTC")
  agronomistDistricts AgronomistDistrict[]
  approvalActions     ApprovalAction[]
  auditLogs           AuditLog[]
  batches             Batch[]
  milestones          BatchMilestone[]
  buyerProfiles       BuyerProfile[]
  certifications      Certification[]
  communities         Community[]
  districts           District[]
  documents           Document[]
  farmLocations       FarmLocation[]
  plots               FarmPlot[]
  farmProfiles        FarmProfile[]
  farmers             Farmer[]
  submissions         FarmerSubmission[]
  fieldActivities     FieldActivity[]
  harvestRecords      HarvestRecord[]
  inputTraceabilities InputTraceability[]
  marketplaceListings MarketplaceListing[]
  movementLogs        MovementLog[]
  notifications       Notification[]
  orders              Order[]
  orderItems          OrderItem[]
  orderMessages       OrderMessage[]
  plantingActivities  PlantingActivity[]
  productionRecords   ProductionRecord[]
  qualityTests        QualityTest[]
  salesRecords        SalesRecord[]
  sessions            Session[]
  users               User[]
  warehouseEntries    WarehouseEntry[]
  traceTheme          OrganizationTraceTheme?
}

model OrganizationTraceTheme {
  id              String       @id @default(cuid())
  organizationId  String       @unique
  heroTitle       String?
  heroSubtitle    String?
  logoUrl         String?
  wordmarkUrl     String?
  primaryColor    String?
  accentColor     String?
  surfaceColor    String?
  backgroundStyle String?
  ctaLabel        String?
  ctaUrl          String?
  footerNote      String?
  showOrgStory    Boolean      @default(false)
  storyTitle      String?
  storyBody       String?
  storyImageUrl   String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model BillingPlan {
  id           String   @id @default(cuid())
  key          String   @unique
  name         String
  priceCents   Int
  currency     String   @default("USD")
  interval     String   @default("month")
  usersLimit   Int
  farmersLimit Int
  batchesLimit Int
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Region {
  id        String     @id @default(cuid())
  name      String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  districts District[]
}

model District {
  id                  String               @id @default(cuid())
  name                String
  regionId            String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  organizationId      String
  agronomistDistricts AgronomistDistrict[]
  communities         Community[]
  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  region              Region               @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@unique([organizationId, regionId, name])
  @@index([organizationId])
}

model Community {
  id             String       @id @default(cuid())
  name           String
  districtId     String
  latitude       Decimal?     @db.Decimal(10, 7)
  longitude      Decimal?     @db.Decimal(10, 7)
  description    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organizationId String
  district       District     @relation(fields: [districtId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  farmers        Farmer[]

  @@unique([organizationId, districtId, name])
  @@index([organizationId])
}

model AgronomistDistrict {
  id             String       @id @default(cuid())
  agronomistId   String
  districtId     String
  createdAt      DateTime     @default(now())
  organizationId String
  agronomist     User         @relation(fields: [agronomistId], references: [id], onDelete: Cascade)
  district       District     @relation(fields: [districtId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([agronomistId, districtId])
  @@index([organizationId])
}

model FarmPlot {
  id                     String              @id @default(cuid())
  farmerId               String
  plotName               String?
  gpsPolygon             Json?
  plotSizeHectare        Decimal?            @db.Decimal(10, 2)
  soilType               String?
  irrigationSource       String?
  previousCrop           String?
  currentCrop            String?
  plantingSeason         String?
  ownershipType          String?
  landDocumentAvailable  Boolean?            @default(false)
  environmentalRiskLevel String?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  organizationId         String
  farmer                 Farmer              @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  organization           Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fieldActivities        FieldActivity[]
  harvestRecords         HarvestRecord[]
  inputTraceabilities    InputTraceability[]
  plantingActivities     PlantingActivity[]
  productionRecords      ProductionRecord[]

  @@index([organizationId])
}

model PlantingActivity {
  id                 String            @id @default(cuid())
  plotId             String
  farmerId           String
  productionRecordId String?
  cropType           String
  varietyName        String?
  seedSource         String?
  seedBatchNumber    String?
  seedQuantityUsed   Decimal?          @db.Decimal(10, 2)
  plantingDate       DateTime
  spacingUsed        String?
  germinationRate    Decimal?          @db.Decimal(5, 2)
  fieldOfficerName   String?
  photosUploaded     Json?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  organizationId     String
  farmer             Farmer            @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  organization       Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plot               FarmPlot          @relation(fields: [plotId], references: [id], onDelete: Cascade)
  productionRecord   ProductionRecord? @relation(fields: [productionRecordId], references: [id])

  @@index([farmerId, plantingDate])
  @@index([plotId, plantingDate])
  @@index([productionRecordId])
  @@index([organizationId])
}

model FieldActivity {
  id                 String            @id @default(cuid())
  plotId             String
  farmerId           String
  productionRecordId String?
  activityType       String
  activityDate       DateTime
  labourUsed         String?
  inputUsed          String?
  quantityApplied    Decimal?          @db.Decimal(10, 2)
  quantityUnit       String?
  weatherCondition   String?
  performedBy        String?
  supervisorVerified Boolean           @default(false)
  geoTaggedPhoto     Json?
  notes              String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  organizationId     String
  farmer             Farmer            @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  organization       Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plot               FarmPlot          @relation(fields: [plotId], references: [id], onDelete: Cascade)
  productionRecord   ProductionRecord? @relation(fields: [productionRecordId], references: [id])

  @@index([farmerId, activityDate])
  @@index([plotId, activityDate])
  @@index([productionRecordId])
  @@index([organizationId])
}

model InputTraceability {
  id              String       @id @default(cuid())
  farmerId        String
  plotId          String
  inputCategory   String
  productName     String
  manufacturer    String?
  batchNumber     String?
  supplier        String?
  purchaseDate    DateTime?
  expiryDate      DateTime?
  quantityUsed    Decimal?     @db.Decimal(10, 2)
  quantityUnit    String?
  applicationDate DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  organizationId  String
  farmer          Farmer       @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plot            FarmPlot     @relation(fields: [plotId], references: [id], onDelete: Cascade)

  @@index([farmerId, applicationDate])
  @@index([plotId, applicationDate])
  @@index([inputCategory])
  @@index([organizationId])
}

model HarvestRecord {
  id                  String            @id @default(cuid())
  plotId              String
  farmerId            String
  productionRecordId  String?
  harvestDate         DateTime
  crop                String
  variety             String?
  quantityHarvested   Decimal?          @db.Decimal(12, 2)
  unit                String?
  harvestMethod       String?
  harvestTeam         String?
  initialQualityGrade String?
  moistureReading     Decimal?          @db.Decimal(5, 2)
  photos              Json?
  supervisorApproved  Boolean           @default(false)
  supervisorName      String?
  notes               String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  organizationId      String
  farmer              Farmer            @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  organization        Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plot                FarmPlot          @relation(fields: [plotId], references: [id], onDelete: Cascade)
  productionRecord    ProductionRecord? @relation(fields: [productionRecordId], references: [id])
  qualityTests        QualityTest[]
  warehouseEntries    WarehouseEntry[]

  @@index([farmerId, harvestDate])
  @@index([plotId, harvestDate])
  @@index([productionRecordId])
  @@index([organizationId])
}

model MovementLog {
  id                 String       @id @default(cuid())
  batchId            String
  fromLocation       String
  toLocation         String
  driverName         String?
  vehicleNumber      String?
  dispatchDate       DateTime
  arrivalDate        DateTime?
  quantitySent       Decimal?     @db.Decimal(12, 2)
  quantityReceived   Decimal?     @db.Decimal(12, 2)
  conditionOnArrival String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  orderId            String?
  organizationId     String
  batch              Batch        @relation(fields: [batchId], references: [id], onDelete: Cascade)
  order              Order?       @relation(fields: [orderId], references: [id])
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([batchId, dispatchDate])
  @@index([organizationId])
}

model WarehouseEntry {
  id                String         @id @default(cuid())
  batchId           String
  harvestId         String?
  warehouseName     String
  warehouseLocation String?
  dateIn            DateTime
  dateOut           DateTime?
  quantityStored    Decimal?       @db.Decimal(12, 2)
  stackNumber       String?
  temperature       Decimal?       @db.Decimal(6, 2)
  humidity          Decimal?       @db.Decimal(6, 2)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  organizationId    String
  batch             Batch          @relation(fields: [batchId], references: [id], onDelete: Cascade)
  harvest           HarvestRecord? @relation(fields: [harvestId], references: [id])
  organization      Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([batchId, dateIn])
  @@index([harvestId])
  @@index([organizationId])
}

model SalesRecord {
  id             String       @id @default(cuid())
  batchId        String
  buyerName      String
  buyerType      String?
  quantitySold   Decimal?     @db.Decimal(12, 2)
  pricePerUnit   Decimal?     @db.Decimal(12, 2)
  totalValue     Decimal?     @db.Decimal(14, 2)
  dateSold       DateTime
  destination    String?
  paymentStatus  String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organizationId String
  batch          Batch        @relation(fields: [batchId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([batchId, dateSold])
  @@index([organizationId])
}

model QualityTest {
  id               String        @id @default(cuid())
  harvestId        String
  dateTested       DateTime
  moisturePct      Decimal?      @db.Decimal(5, 2)
  foreignMatterPct Decimal?      @db.Decimal(5, 2)
  brokenGrainPct   Decimal?      @db.Decimal(5, 2)
  colorGrade       String?
  pestDamage       String?
  aflatoxinTest    String?
  passed           Boolean
  testedBy         String?
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  organizationId   String
  harvest          HarvestRecord @relation(fields: [harvestId], references: [id], onDelete: Cascade)
  organization     Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([harvestId, dateTested])
  @@index([passed])
  @@index([organizationId])
}

model MarketplaceListing {
  id               String        @id @default(cuid())
  batchId          String        @unique
  title            String
  description      String?
  price            Decimal       @db.Decimal(12, 2)
  currency         String        @default("USD")
  status           ListingStatus @default(DRAFT)
  images           String[]      @default([])
  category         String?
  tags             String[]      @default([])
  isFeatured       Boolean       @default(false)
  minOrderQuantity Decimal?      @db.Decimal(12, 2)
  unit             String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @default(now()) @updatedAt
  organizationId   String
  batch            Batch         @relation(fields: [batchId], references: [id], onDelete: Cascade)
  organization     Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([category])
  @@index([organizationId])
}

model Order {
  id              String         @id @default(cuid())
  orderNumber     String         @unique
  buyerId         String
  status          OrderStatus    @default(PENDING)
  totalAmount     Decimal?       @db.Decimal(14, 2)
  currency        String         @default("USD")
  shippingAddress String?
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  organizationId  String
  movements       MovementLog[]
  buyer           User           @relation("BuyerOrders", fields: [buyerId], references: [id])
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items           OrderItem[]
  messages        OrderMessage[]

  @@index([buyerId])
  @@index([status])
  @@index([organizationId])
}

model OrderMessage {
  id             String       @id @default(cuid())
  orderId        String
  senderId       String
  content        String
  createdAt      DateTime     @default(now())
  organizationId String
  order          Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id])

  @@index([orderId])
  @@index([senderId])
  @@index([organizationId])
}

model OrderItem {
  id             String       @id @default(cuid())
  orderId        String
  batchId        String
  quantity       Decimal      @db.Decimal(12, 2)
  unit           String?
  pricePerUnit   Decimal      @db.Decimal(12, 2)
  totalPrice     Decimal      @db.Decimal(14, 2)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organizationId String
  batch          Batch        @relation(fields: [batchId], references: [id])
  order          Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([batchId])
  @@index([organizationId])
}

model BuyerProfile {
  id              String       @id @default(cuid())
  userId          String       @unique
  companyName     String
  phoneNumber     String?
  businessAddress String?
  country         String?
  taxId           String?
  businessType    String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

